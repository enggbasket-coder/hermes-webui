# Where Hermes profiles live on disk. Inside the container this is the
# mountpoint of your host's Hermes data dir (see docker-compose.yml).
# The dashboard expects: $HERMES_HOME/profiles/<profile-name>/<hermes-root-layout>
HERMES_HOME=/data/hermes

# Path to the hermes CLI binary inside the container. Leave as "hermes" if
# you installed hermes-agent in the image; set to an absolute path otherwise.
HERMES_BIN=hermes

# Dashboard auth. Generate SESSION_SECRET with: openssl rand -hex 32
AUTH_PASSWORD=change-me-please
SESSION_SECRET=replace-with-64-hex-chars-from-openssl-rand-hex-32

# Port the Next.js server binds inside the container.
PORT=7878

# Set to 1 only when testing over plain HTTP (no TLS yet). Disables the
# Secure flag on the session cookie so it works without HTTPS. Set back
# to 0 (or remove) once you're behind Nginx + Let's Encrypt.
COOKIE_INSECURE=0
